{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "public": "dist/client",
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "^/assets/.*",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "^/.*\\.[^/]*$",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
